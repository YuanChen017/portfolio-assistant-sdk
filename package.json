{
  "name": "@yuanchen710/portfolio-assistant-sdk",
  "version": "1.0.0",
  "description": "Plug-and-play AI chatbot widget for portfolio sites — resume upload, job match analysis, streaming responses",
  "type": "module",
  "main": "dist/portfolio-assistant-sdk.umd.cjs",
  "module": "dist/portfolio-assistant-sdk.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "keywords": [
    "portfolio",
    "chatbot",
    "ai",
    "widget",
    "react",
    "resume",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/YuanChen/portfolio-assistant-sdk.git"
  },
  "homepage": "https://github.com/YuanChen/portfolio-assistant-sdk#readme",
  "exports": {
    ".": {
      "import": "./dist/portfolio-assistant-sdk.js",
      "require": "./dist/portfolio-assistant-sdk.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "pdfjs-dist": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "pdfjs-dist": "^4.8.69",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "dependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
