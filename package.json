{
  "name": "portfolio-assistant-sdk",
  "version": "1.0.0",
  "description": "Reusable AI chatbot widget SDK for Yuan Chen's portfolio",
  "type": "module",
  "main": "dist/portfolio-assistant-sdk.umd.cjs",
  "module": "dist/portfolio-assistant-sdk.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/portfolio-assistant-sdk.js",
      "require": "./dist/portfolio-assistant-sdk.umd.cjs"
    },
    "./styles": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "pdfjs-dist": ">=4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "pdfjs-dist": "^4.8.69",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0"
  },
  "dependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
